# PiCrawler Agent Environment
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# === LLM Configuration ===
LLM_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# LLM Parameters
OPENAI_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# === Agent Identity (change per robot) ===
AGENT_ID=crawler-alpha-patrol-001
AGENT_PORT=9004

# === Central Computer ===
CENTRAL_URL=http://192.168.1.100
CENTRAL_GATEWAY_PORT=8080

# === Camera ===
STREAM_PORT=9000

# === Speaker (TTS + sound effects, default OFF) ===
SPEAKER_ENABLED=false

# === Calibration ===
OBSTACLE_THRESHOLD_CM=20.0
PATROL_SPEED=50
